# Postgres connection string (dev compose: postgres://rustify:rustify@localhost:5433/rustify)
DATABASE_URL=postgres://rustify:rustify@localhost:5433/rustify
# 32-byte base64 key for AES-256-GCM encryption at rest (generate: openssl rand -base64 32)
RUSTIFY_SECRET_KEY=
# Initial admin user seeded on first boot
RUSTIFY_ADMIN_EMAIL=admin@example.com
RUSTIFY_ADMIN_PASSWORD=
