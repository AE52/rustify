{
  "openapi": "3.1.0",
  "info": {
    "title": "Rustify API",
    "description": "Hand-written snapshot of Contract C5 (REST surface) until rustify-server generates the real openapi.json. Field names follow C6 (snake_case, uuid external ids). Replace via `npm run gen:api` after Track F merges.",
    "version": "0.1.0"
  },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/auth/login": {
      "post": {
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in; sets session cookie",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "logout",
        "responses": { "204": { "description": "Logged out" } }
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/User" } }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/private-keys": {
      "get": {
        "operationId": "listPrivateKeys",
        "responses": {
          "200": {
            "description": "Private keys",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/PrivateKey" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPrivateKey",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKeyCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKey" } }
            }
          },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/private-keys/generate": {
      "post": {
        "operationId": "generatePrivateKey",
        "description": "Generates an ed25519 key pair server-side; the private key stays server-side, public key returned.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKeyGenerate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Generated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKey" } }
            }
          }
        }
      }
    },
    "/private-keys/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getPrivateKey",
        "responses": {
          "200": {
            "description": "Private key",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKey" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "operationId": "updatePrivateKey",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKeyUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PrivateKey" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "operationId": "deletePrivateKey",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/servers": {
      "get": {
        "operationId": "listServers",
        "responses": {
          "200": {
            "description": "Servers",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Server" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createServer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ServerCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Server" } }
            }
          },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/servers/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getServer",
        "responses": {
          "200": {
            "description": "Server",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Server" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "operationId": "updateServer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ServerUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Server" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "operationId": "deleteServer",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/servers/{uuid}/validate": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "validateServer",
        "description": "Starts async validation; output streams on WS channel `server:<uuid>`.",
        "responses": {
          "202": {
            "description": "Validation started",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ValidateResponse" } }
            }
          }
        }
      }
    },
    "/servers/{uuid}/proxy": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getServerProxy",
        "responses": {
          "200": {
            "description": "Proxy config",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProxyConfig" } }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateServerProxy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ProxyConfigUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Saved",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProxyConfig" } }
            }
          }
        }
      }
    },
    "/servers/{uuid}/proxy/start": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "startServerProxy",
        "responses": { "202": { "description": "Proxy start queued" } }
      }
    },
    "/servers/{uuid}/proxy/stop": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "stopServerProxy",
        "responses": { "202": { "description": "Proxy stop queued" } }
      }
    },
    "/servers/{uuid}/proxy/restart": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "restartServerProxy",
        "responses": { "202": { "description": "Proxy restart queued" } }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "responses": {
          "200": {
            "description": "Projects",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "description": "Auto-creates a `production` environment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Project" } }
            }
          }
        }
      }
    },
    "/projects/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getProject",
        "responses": {
          "200": {
            "description": "Project with environments",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Project" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "operationId": "updateProject",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ProjectUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Project" } }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/projects/{uuid}/environments": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "listEnvironments",
        "responses": {
          "200": {
            "description": "Environments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Environment" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEnvironment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EnvironmentCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Environment" } }
            }
          }
        }
      }
    },
    "/applications": {
      "get": {
        "operationId": "listApplications",
        "parameters": [
          {
            "name": "project_uuid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "environment_uuid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Applications",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Application" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createApplication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ApplicationCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Application" } }
            }
          },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/applications/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getApplication",
        "responses": {
          "200": {
            "description": "Application",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Application" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "operationId": "updateApplication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ApplicationUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Application" } }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteApplication",
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/applications/{uuid}/deploy": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "deployApplication",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DeployRequest" } }
          }
        },
        "responses": {
          "202": {
            "description": "Deployment queued",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/DeployResponse" } }
            }
          }
        }
      }
    },
    "/applications/{uuid}/stop": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "stopApplication",
        "responses": { "202": { "description": "Stop queued" } }
      }
    },
    "/applications/{uuid}/restart": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "restartApplication",
        "responses": { "202": { "description": "Restart queued" } }
      }
    },
    "/applications/{uuid}/envs": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "listEnvVars",
        "responses": {
          "200": {
            "description": "Environment variables",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/EnvVar" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEnvVar",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EnvVarCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/EnvVar" } }
            }
          },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/applications/{uuid}/envs/{env_uuid}": {
      "parameters": [
        { "$ref": "#/components/parameters/Uuid" },
        {
          "name": "env_uuid",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "patch": {
        "operationId": "updateEnvVar",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EnvVarUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/EnvVar" } }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteEnvVar",
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/applications/{uuid}/logs": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getApplicationLogs",
        "parameters": [
          {
            "name": "lines",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "Container logs (docker logs -n)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ContainerLogs" } }
            }
          }
        }
      }
    },
    "/deployments": {
      "get": {
        "operationId": "listDeployments",
        "parameters": [
          {
            "name": "application_uuid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deployments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Deployment" } }
              }
            }
          }
        }
      }
    },
    "/deployments/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "get": {
        "operationId": "getDeployment",
        "responses": {
          "200": {
            "description": "Deployment incl. logs[] (C3 LogLine)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/DeploymentDetail" } }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/deployments/{uuid}/cancel": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "post": {
        "operationId": "cancelDeployment",
        "responses": {
          "202": { "description": "Cancel requested" },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/settings": {
      "get": {
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Instance settings",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/InstanceSettings" } }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateSettings",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/InstanceSettingsUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/InstanceSettings" } }
            }
          }
        }
      }
    },
    "/api-tokens": {
      "get": {
        "operationId": "listApiTokens",
        "responses": {
          "200": {
            "description": "API tokens (no secrets)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ApiToken" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createApiToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ApiTokenCreate" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created; `token` is shown exactly once",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiTokenCreated" } }
            }
          }
        }
      }
    },
    "/api-tokens/{uuid}": {
      "parameters": [{ "$ref": "#/components/parameters/Uuid" }],
      "delete": {
        "operationId": "deleteApiToken",
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/health": {
      "get": {
        "operationId": "health",
        "security": [],
        "responses": {
          "200": {
            "description": "Liveness",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Health" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Uuid": {
        "name": "uuid",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "Error": {
        "description": "Error envelope",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ApiErrorBody" } }
        }
      }
    },
    "schemas": {
      "ApiErrorBody": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "Health": {
        "type": "object",
        "required": ["status"],
        "properties": { "status": { "type": "string", "enum": ["ok"] } }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["user"],
        "properties": { "user": { "$ref": "#/components/schemas/User" } }
      },
      "User": {
        "type": "object",
        "required": ["id", "email", "name"],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "PrivateKey": {
        "type": "object",
        "required": ["uuid", "name", "public_key", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "public_key": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PrivateKeyCreate": {
        "type": "object",
        "required": ["name", "private_key"],
        "properties": {
          "name": { "type": "string" },
          "private_key": { "type": "string", "description": "write-only" }
        }
      },
      "PrivateKeyUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "private_key": { "type": "string", "description": "write-only" }
        }
      },
      "PrivateKeyGenerate": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      },
      "Server": {
        "type": "object",
        "required": ["uuid", "name", "ip", "port", "user", "private_key_uuid", "reachable", "usable", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "ip": { "type": "string" },
          "port": { "type": "integer" },
          "user": { "type": "string" },
          "private_key_uuid": { "type": "string" },
          "reachable": { "type": "boolean" },
          "usable": { "type": "boolean" },
          "validation_logs": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ServerCreate": {
        "type": "object",
        "required": ["name", "ip", "private_key_uuid"],
        "properties": {
          "name": { "type": "string" },
          "ip": { "type": "string" },
          "port": { "type": "integer", "default": 22 },
          "user": { "type": "string", "default": "root" },
          "private_key_uuid": { "type": "string" }
        }
      },
      "ServerUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "ip": { "type": "string" },
          "port": { "type": "integer" },
          "user": { "type": "string" },
          "private_key_uuid": { "type": "string" }
        }
      },
      "ValidateResponse": {
        "type": "object",
        "required": ["job_uuid"],
        "properties": { "job_uuid": { "type": "string" } }
      },
      "ProxyConfig": {
        "type": "object",
        "required": ["proxy_type", "proxy_status"],
        "properties": {
          "proxy_type": { "type": "string" },
          "proxy_status": { "type": "string" },
          "proxy_custom_config": { "type": ["string", "null"] }
        }
      },
      "ProxyConfigUpdate": {
        "type": "object",
        "properties": {
          "proxy_custom_config": { "type": ["string", "null"] }
        }
      },
      "Project": {
        "type": "object",
        "required": ["uuid", "name", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "environments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Environment" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ProjectCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] }
        }
      },
      "ProjectUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] }
        }
      },
      "Environment": {
        "type": "object",
        "required": ["uuid", "name"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "EnvironmentCreate": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      },
      "BuildPack": {
        "type": "string",
        "enum": ["nixpacks", "dockerfile", "static", "docker_image", "docker_compose"]
      },
      "Application": {
        "type": "object",
        "required": [
          "uuid", "name", "environment_uuid", "server_uuid", "git_repository", "git_branch",
          "git_commit_sha", "build_pack", "base_directory", "ports_exposes", "status", "created_at"
        ],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "fqdn": { "type": ["string", "null"] },
          "environment_uuid": { "type": "string" },
          "project_uuid": { "type": "string" },
          "server_uuid": { "type": "string" },
          "git_repository": { "type": "string" },
          "git_branch": { "type": "string" },
          "git_commit_sha": { "type": "string" },
          "build_pack": { "$ref": "#/components/schemas/BuildPack" },
          "static_image": { "type": "string" },
          "docker_registry_image_name": { "type": ["string", "null"] },
          "docker_registry_image_tag": { "type": ["string", "null"] },
          "dockerfile_location": { "type": "string" },
          "docker_compose_location": { "type": "string" },
          "base_directory": { "type": "string" },
          "publish_directory": { "type": ["string", "null"] },
          "install_command": { "type": ["string", "null"] },
          "build_command": { "type": ["string", "null"] },
          "start_command": { "type": ["string", "null"] },
          "ports_exposes": { "type": "string" },
          "ports_mappings": { "type": ["string", "null"] },
          "health_check_enabled": { "type": "boolean" },
          "health_check_path": { "type": "string" },
          "health_check_port": { "type": ["string", "null"] },
          "health_check_host": { "type": "string" },
          "health_check_method": { "type": "string" },
          "health_check_return_code": { "type": "integer" },
          "health_check_interval": { "type": "integer" },
          "health_check_timeout": { "type": "integer" },
          "health_check_retries": { "type": "integer" },
          "health_check_start_period": { "type": "integer" },
          "limits_memory": { "type": "string" },
          "limits_cpus": { "type": "string" },
          "custom_docker_run_options": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ApplicationCreate": {
        "type": "object",
        "required": ["project_uuid", "environment_name", "server_uuid", "name", "git_repository"],
        "properties": {
          "project_uuid": { "type": "string" },
          "environment_name": { "type": "string" },
          "server_uuid": { "type": "string" },
          "name": { "type": "string" },
          "git_repository": { "type": "string" },
          "git_branch": { "type": "string", "default": "main" },
          "build_pack": { "$ref": "#/components/schemas/BuildPack" },
          "ports_exposes": { "type": "string", "default": "80" },
          "fqdn": { "type": ["string", "null"] },
          "base_directory": { "type": "string" },
          "publish_directory": { "type": ["string", "null"] },
          "dockerfile_location": { "type": "string" },
          "docker_compose_location": { "type": "string" },
          "static_image": { "type": "string" },
          "install_command": { "type": ["string", "null"] },
          "build_command": { "type": ["string", "null"] },
          "start_command": { "type": ["string", "null"] }
        }
      },
      "ApplicationUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "fqdn": { "type": ["string", "null"] },
          "git_repository": { "type": "string" },
          "git_branch": { "type": "string" },
          "git_commit_sha": { "type": "string" },
          "build_pack": { "$ref": "#/components/schemas/BuildPack" },
          "static_image": { "type": "string" },
          "dockerfile_location": { "type": "string" },
          "docker_compose_location": { "type": "string" },
          "base_directory": { "type": "string" },
          "publish_directory": { "type": ["string", "null"] },
          "install_command": { "type": ["string", "null"] },
          "build_command": { "type": ["string", "null"] },
          "start_command": { "type": ["string", "null"] },
          "ports_exposes": { "type": "string" },
          "ports_mappings": { "type": ["string", "null"] },
          "health_check_enabled": { "type": "boolean" },
          "health_check_path": { "type": "string" },
          "limits_memory": { "type": "string" },
          "limits_cpus": { "type": "string" },
          "custom_docker_run_options": { "type": ["string", "null"] }
        }
      },
      "DeployRequest": {
        "type": "object",
        "properties": { "force_rebuild": { "type": "boolean", "default": false } }
      },
      "DeployResponse": {
        "type": "object",
        "required": ["deployment_uuid"],
        "properties": { "deployment_uuid": { "type": "string" } }
      },
      "EnvVar": {
        "type": "object",
        "required": ["uuid", "key", "is_buildtime", "is_literal", "is_shown_once", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "key": { "type": "string" },
          "value": {
            "type": ["string", "null"],
            "description": "null once a shown-once variable has been read"
          },
          "is_buildtime": { "type": "boolean" },
          "is_literal": { "type": "boolean" },
          "is_shown_once": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "EnvVarCreate": {
        "type": "object",
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" },
          "is_buildtime": { "type": "boolean", "default": false },
          "is_literal": { "type": "boolean", "default": false },
          "is_shown_once": { "type": "boolean", "default": false }
        }
      },
      "EnvVarUpdate": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" },
          "is_buildtime": { "type": "boolean" },
          "is_literal": { "type": "boolean" },
          "is_shown_once": { "type": "boolean" }
        }
      },
      "ContainerLogs": {
        "type": "object",
        "required": ["logs"],
        "properties": { "logs": { "type": "string" } }
      },
      "DeploymentStatus": {
        "type": "string",
        "enum": ["queued", "in_progress", "finished", "failed", "cancelled"]
      },
      "Deployment": {
        "type": "object",
        "required": ["uuid", "application_uuid", "server_uuid", "status", "force_rebuild", "rollback", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "application_uuid": { "type": "string" },
          "server_uuid": { "type": "string" },
          "status": { "$ref": "#/components/schemas/DeploymentStatus" },
          "commit_sha": { "type": ["string", "null"] },
          "commit_message": { "type": ["string", "null"] },
          "force_rebuild": { "type": "boolean" },
          "rollback": { "type": "boolean" },
          "started_at": { "type": ["string", "null"], "format": "date-time" },
          "finished_at": { "type": ["string", "null"], "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "LogLine": {
        "type": "object",
        "description": "Contract C3 log line (JSON field `order` maps to DB column `ord`)",
        "required": ["order", "kind", "content", "hidden", "batch", "timestamp"],
        "properties": {
          "order": { "type": "integer", "format": "int64" },
          "kind": { "type": "string", "enum": ["stdout", "stderr", "info"] },
          "content": { "type": "string" },
          "hidden": { "type": "boolean" },
          "batch": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "DeploymentDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/Deployment" },
          {
            "type": "object",
            "required": ["logs"],
            "properties": {
              "logs": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/LogLine" }
              }
            }
          }
        ]
      },
      "InstanceSettings": {
        "type": "object",
        "required": ["registration_enabled"],
        "properties": {
          "fqdn": { "type": ["string", "null"] },
          "wildcard_domain": { "type": ["string", "null"] },
          "registration_enabled": { "type": "boolean" }
        }
      },
      "InstanceSettingsUpdate": {
        "type": "object",
        "properties": {
          "fqdn": { "type": ["string", "null"] },
          "wildcard_domain": { "type": ["string", "null"] },
          "registration_enabled": { "type": "boolean" }
        }
      },
      "ApiToken": {
        "type": "object",
        "required": ["uuid", "name", "abilities", "created_at"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "abilities": { "type": "array", "items": { "type": "string" } },
          "last_used_at": { "type": ["string", "null"], "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ApiTokenCreate": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      },
      "ApiTokenCreated": {
        "type": "object",
        "required": ["uuid", "name", "token"],
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "token": { "type": "string", "description": "shown exactly once" }
        }
      }
    }
  }
}
